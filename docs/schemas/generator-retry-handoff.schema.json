{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://landinghub.local/schemas/generator-retry-handoff.schema.json",
  "title": "Generator Retry Handoff",
  "description": "Retry-specific Generator handoff extension generated from Validator FAIL results.",
  "allOf": [
    {
      "$ref": "./generator-handoff.schema.json"
    },
    {
      "type": "object",
      "additionalProperties": true,
      "required": ["retry"],
      "properties": {
        "retry": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "attempt_no",
            "previous_attempts",
            "retry_instruction",
            "same_error_repeat_count"
          ],
          "properties": {
            "attempt_no": {
              "type": "integer",
              "minimum": 2,
              "maximum": 4
            },
            "previous_attempts": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "attempt_no",
                  "generator_result_path",
                  "validator_result_path",
                  "validator_feedback"
                ],
                "properties": {
                  "attempt_no": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "generator_result_path": {
                    "type": "string"
                  },
                  "validator_result_path": {
                    "type": "string"
                  },
                  "generator_result_summary": {
                    "type": "string"
                  },
                  "validator_feedback": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": true,
                      "required": [
                        "severity",
                        "evidence_type",
                        "location",
                        "description",
                        "suggestion",
                        "evidence"
                      ]
                    }
                  }
                }
              }
            },
            "retry_instruction": {
              "type": "string",
              "minLength": 1
            },
            "same_error_repeat_count": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    }
  ]
}
